# Copy to `.env` and fill only the providers you plan to use.
# cp .env.template .env

# OpenAI
OPENAI_API_KEY=your_openai_key

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key

# Google Gemini (OpenAI-compatible endpoint)
GOOGLE_API_KEY=your_google_key

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_key

# Optional OpenRouter gateway
OPENROUTER_API_KEY=your_openrouter_key

# Local CLI exec mode for subscription/OAuth-backed Codex and Claude Code.
# These CLIs store credentials outside `.env`, so do not paste OAuth tokens here.
# 1) `codex login` and choose ChatGPT or API auth
# 2) `claude auth login` or `claude setup-token`
# Then use model names `codex-exec` or `claude-exec`.
LLM_QUEST_CODEX_EXEC_PATH=codex
LLM_QUEST_CODEX_EXEC_MODEL=
LLM_QUEST_CODEX_EXEC_ARGS=

LLM_QUEST_CLAUDE_EXEC_PATH=claude
LLM_QUEST_CLAUDE_EXEC_MODEL=
LLM_QUEST_CLAUDE_EXEC_ARGS=

# Langfuse tracing (optional). When set, all LLM calls are traced automatically.
# Sign up at https://cloud.langfuse.com or self-host.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional token pricing overrides (USD per 1M tokens) used for run cost estimates.
# If omitted, built-in defaults are used for known models.
# Format:
# LLM_PRICE_<PROVIDER>_<MODEL>_INPUT_PER_M=...
# LLM_PRICE_<PROVIDER>_<MODEL>_OUTPUT_PER_M=...
# Example for gpt-5-mini:
# LLM_PRICE_OPENAI_GPT_5_MINI_INPUT_PER_M=0.25
# LLM_PRICE_OPENAI_GPT_5_MINI_OUTPUT_PER_M=2.0
